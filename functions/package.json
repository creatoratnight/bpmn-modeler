{
  "name": "bpmn-modeler-functions",
  "description": "Cloud Functions for bpmn-modeler",
  "scripts": {
    "build": "tsc",
    "sync-config": "node scripts/sync-config.js",
    "preemulate": "npm run sync-config",
    "emulate": "npm run build && node scripts/start-emulator.js",
    "serve": "npm run build && node scripts/start-emulator.js",
    "pretest": "npm run sync-config",
    "test": "jest",
    "deploy": "node scripts/deploy.js"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/billing": "^5.1.1",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.2.2",
    "google-auth-library": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/src/**/*.test.ts"],
    "setupFiles": ["./jest.setup.js"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    }
  },
  "private": true
}
